{
  "name": "boutiqueforaweek",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "css:dev": "sass _css/style.scss:css/style.css --watch",
    "css:build": "sass _css/style.scss:_site/css/style.css --no-source-map",
    "css:prod": "postcss _site/css/style.css --replace",
    "js:dev": "cp node_modules/bootstrap/dist/js/bootstrap.bundle.js js/script.js",
    "js:build": "mkdir -p _site/js && cp node_modules/bootstrap/dist/js/bootstrap.bundle.min.js _site/js/script.js",
    "eleventy:serve": "npx @11ty/eleventy --serve",
    "eleventy:build": "npx @11ty/eleventy",
    "dev": "npm run js:dev && npm-run-all2 --parallel css:dev eleventy:serve",
    "build": "npm-run-all2 --serial eleventy:build css:build css:prod js:build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boutiqueforaweek/boutiqueforaweek.github.io.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/boutiqueforaweek/boutiqueforaweek.github.io/issues"
  },
  "homepage": "https://github.com/boutiqueforaweek/boutiqueforaweek.github.io#readme",
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@fullhuman/postcss-purgecss": "^7.0.0",
    "bootstrap": "^5.3.2",
    "cssnano": "^7.0.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.5.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.4.32",
    "postcss-cli": "^11.0.1",
    "postcss-discard-comments": "^7.0.0",
    "sass": "^1.69.5"
  }
}
