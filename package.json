{
  "name": "boutiqueforaweek",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "css:dev": "sass src/_css/style.scss:src/css/style.css --watch",
    "css:build": "sass src/_css/style.scss:_site/css/style.css --no-source-map",
    "css:prod": "lightningcss --minify --targets '>= 0.25%' _site/css/style.css -o _site/css/style.css",
    "eleventy:serve": "npx @11ty/eleventy --serve",
    "eleventy:build": "npx @11ty/eleventy",
    "dev": "npm-run-all2 --parallel css:dev eleventy:serve",
    "build": "npm-run-all2 --serial eleventy:build css:build css:prod",
    "gen:workflow": "node scripts/gen-workflow.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boutiqueforaweek/boutiqueforaweek.github.io.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/boutiqueforaweek/boutiqueforaweek.github.io/issues"
  },
  "homepage": "https://github.com/boutiqueforaweek/boutiqueforaweek.github.io#readme",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-navigation": "^1.0.5",
    "bootstrap": "^5.3.8",
    "html-minifier-terser": "^7.2.0",
    "lightningcss-cli": "^1.32.0",
    "markdown-it": "^14.2.0",
    "markdown-it-attrs": "^5.0.0",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.100.0"
  },
  "devDependencies": {
    "@11ty/eleventy-img": "^6.0.4"
  }
}
